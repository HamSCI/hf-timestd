[Unit]
Description=HF-TimeStd IRI Indices Health Check
Documentation=https://github.com/HamSCI/hf-timestd
After=timestd-iri-update.service
OnFailure=timestd-alert@%N.service

[Service]
Type=oneshot
User=timestd
Group=timestd

# Operator identity (callsign, grid) from sigmond — CLIENT-CONTRACT §14.2
EnvironmentFile=-/etc/sigmond/coordination.env

ExecStart=/opt/git/sigmond/hf-timestd/scripts/iri-indices-healthcheck.sh

TimeoutStartSec=60

StandardOutput=journal
StandardError=journal
SyslogIdentifier=timestd-iri-healthcheck

# Hardening: read-only access to the IRI dat dir; no writes anywhere
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
