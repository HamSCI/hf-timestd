[Unit]
Description=hf-timestd data retention pruning
Documentation=https://github.com/mijahauan/hf-timestd
After=local-fs.target

[Service]
Type=oneshot
User=timestd
Group=timestd

# Uses the QuotaManager to enforce storage policy:
#   1. Trim derived data (phase2, products) older than 7 days
#   2. Archive completed raw IQ days to archive-root (if mounted)
#   3. If disk > 80%, evict by priority: products → phase2 → vtec → raw_iq
# Raw IQ is preserved on archive storage; only deleted as last resort.
# Operator identity (callsign, grid) from sigmond — CLIENT-CONTRACT §14.2
EnvironmentFile=-/etc/sigmond/coordination.env

ExecStart=/opt/hf-timestd/venv/bin/python -m hf_timestd.quota_manager \
    --data-root /var/lib/timestd \
    --threshold 80 \
    --min-days 2 \
    --max-derived-days 7 \
    --archive-root /mnt/timestd-archive \
    -v

StandardOutput=journal
StandardError=journal
SyslogIdentifier=timestd-prune

# Limit I/O priority so prune does not starve the recording services
IOSchedulingClass=idle
CPUSchedulingPolicy=idle
Nice=19
