[Unit]
Description=HF-TimeStd IONEX Download Service
Documentation=https://github.com/mijahauan/hf-timestd
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=3600
StartLimitBurst=3
OnFailure=timestd-alert@%n.service

[Service]
Type=oneshot
User=timestd
Group=timestd

# Environment
# Operator identity (callsign, grid) from sigmond — CLIENT-CONTRACT §14.2
EnvironmentFile=-/etc/sigmond/coordination.env

EnvironmentFile=-/etc/hf-timestd/environment
Environment=NETRC=/etc/hf-timestd/earthdata-netrc

# Run the download script
ExecStart=/opt/hf-timestd/scripts/download_ionex_daily.sh

# Retry on failure (up to 3 attempts with 5 minute delay)
Restart=on-failure
RestartSec=300

# Timeout (IONEX download should complete within 5 minutes)
TimeoutStartSec=300

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=timestd-ionex

[Install]
WantedBy=multi-user.target
