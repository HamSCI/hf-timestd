# Logrotate configuration for HF-TimeStd
# Install to: /etc/logrotate.d/timestd

/var/log/hf-timestd/*.log {
    # Rotate daily
    daily
    
    # Keep 14 days of logs
    rotate 14
    
    # Compress old logs
    compress
    delaycompress
    
    # Don't error if log file is missing
    missingok
    notifempty
    
    # Long-running services keep file descriptors open (StandardOutput=append).
    # copytruncate keeps the same inode so logs continue in *.log after rotate.
    copytruncate
    
    # Use date extension instead of numbers
    dateext
    dateformat -%Y%m%d
    
    # Shared scripts block intentionally omitted: no daemon signal needed with copytruncate.
}

# Separate config for data retention log (less frequent rotation)
/var/log/hf-timestd/data-retention.log {
    weekly
    rotate 8
    compress
    delaycompress
    missingok
    notifempty
    create 0644 timestd timestd
}
