# Logrotate configuration for HF-TimeStd auxiliary log files.
# Install to: /etc/logrotate.d/timestd
#
# As of v6.12, every `timestd-*` systemd unit logs to journald; journald
# handles its own rotation via SystemMaxUse= in /etc/systemd/journald.conf
# (see docs/DEBUGGING.md §2).
#
# The only files covered below are legacy paths maintained by non-systemd
# helper scripts that still write to /var/log/hf-timestd/:
#   - data-retention.log  (written by scripts/data-retention cron, if used)
#   - freshness-monitor.log (written by scripts/check-freshness-alert.sh)
#
# If none of those scripts are configured on a given host this file is a no-op.

/var/log/hf-timestd/data-retention.log {
    weekly
    rotate 8
    compress
    delaycompress
    missingok
    notifempty
    create 0644 timestd timestd
}

/var/log/hf-timestd/freshness-monitor.log {
    weekly
    rotate 4
    compress
    delaycompress
    missingok
    notifempty
    create 0644 timestd timestd
}
