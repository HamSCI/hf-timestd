{
    "schema_version": "2.0.0",
    "data_product": "L2_tick_timing",
    "description": "Per-minute tick timing from TickEdgeDetector ensemble. D_clock from AM-domain front-edge detection (UTC-referenced), Doppler from carrier phase slope across the minute, SNR from per-tick matched filter correlation.",
    "cadence_seconds": 60,
    "processing_level": "L2",
    "standards": [
        "ITU-R TF.460-6 Standard-frequency and time-signal emissions"
    ],
    "reference": "Per-second timing ticks from WWV/WWVH/CHU/BPM",
    "quality_flags": {
        "GOOD": "High confidence with >30 detected edges",
        "MARGINAL": "Moderate confidence with 10-30 detected edges",
        "BAD": "Low confidence with <10 detected edges",
        "MISSING": "Insufficient ticks detected"
    },
    "fields": [
        {
            "name": "timestamp_utc",
            "type": "string",
            "format": "iso8601",
            "required": true,
            "description": "Measurement timestamp in UTC"
        },
        {
            "name": "minute_boundary_utc",
            "type": "integer",
            "required": true,
            "description": "Unix epoch timestamp of minute boundary"
        },
        {
            "name": "channel",
            "type": "string",
            "required": true,
            "description": "Channel name (e.g., SHARED_10000)"
        },
        {
            "name": "station",
            "type": "string",
            "required": true,
            "description": "Detected station (WWV, WWVH, CHU, BPM)"
        },
        {
            "name": "frequency_mhz",
            "type": "float",
            "required": false,
            "description": "Broadcast frequency in MHz"
        },
        {
            "name": "mean_snr_db",
            "type": "float",
            "required": true,
            "description": "Mean per-tick matched filter SNR (dB)"
        },
        {
            "name": "valid_windows",
            "type": "integer",
            "required": true,
            "description": "Number of ticks with valid detections"
        },
        {
            "name": "total_windows",
            "type": "integer",
            "required": true,
            "description": "Total number of seconds attempted"
        },
        {
            "name": "overall_confidence",
            "type": "float",
            "required": false,
            "description": "Overall detection confidence (0-1)"
        },
        {
            "name": "expected_delay_ms",
            "type": "float",
            "required": false,
            "description": "Expected propagation delay from physics model (ms)"
        },
        {
            "name": "d_clock_ms",
            "type": "float",
            "required": false,
            "description": "D_clock: ensemble timing residual from expected arrival (ms). Positive = late arrival (longer ionospheric path)."
        },
        {
            "name": "d_clock_uncertainty_ms",
            "type": "float",
            "required": false,
            "description": "D_clock uncertainty from MAD of per-tick timing errors (ms)"
        },
        {
            "name": "d_clock_source",
            "type": "string",
            "required": false,
            "description": "Source of D_clock estimate (edge_ensemble)"
        },
        {
            "name": "doppler_hz",
            "type": "float",
            "required": false,
            "description": "Doppler shift from carrier phase slope across the minute (Hz)"
        },
        {
            "name": "doppler_uncertainty_hz",
            "type": "float",
            "required": false,
            "description": "Doppler uncertainty from linear fit residuals (Hz)"
        },
        {
            "name": "ensemble_n_edges",
            "type": "integer",
            "required": false,
            "description": "Number of tick edges used in ensemble"
        },
        {
            "name": "n_clean",
            "type": "integer",
            "required": false,
            "description": "Number of ticks from clean (no-intermod) minutes"
        },
        {
            "name": "processed_at",
            "type": "string",
            "format": "iso8601",
            "required": false,
            "description": "ISO 8601 timestamp when record was written"
        },
        {
            "name": "processing_version",
            "type": "string",
            "required": false,
            "description": "Processing software version"
        }
    ]
}
